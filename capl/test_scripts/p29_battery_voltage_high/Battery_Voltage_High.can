testcase tc_Recovery()
{
  int battVoltage_arr[14] = {0,1,7500,14999,15000,15001, 15400,15500,15501, 17000,20000,20001,25000, 32767};
  int battFaultVoltage_arr[4] = {15501, 17000, 20001,32767};
  int RecoverybattVoltage;
  int idx;

  int preCondOk;
  int recoveryDetectedInWindow;
  int unexpectedRecoveryDetected;
  int timingError;
  int expectRecovery;

  int count =0;
  
  for(idx=0; idx<elCount(battVoltage_arr); idx++)
  {
    RecoverybattVoltage = battVoltage_arr[idx];
    for(i=0; i<=1; i++){
      for(j=0; j<=1; j++){
        
        initializeSysVar();
        clearAllFaults();
        count++;
        
        preCondOk = 0;
        recoveryDetectedInWindow = 0;
        unexpectedRecoveryDetected = 0;
        timingError = 0;

        /* 1) 먼저 fault level 2 precondition 만들기 */
        @sysvar::Sensors::Ignition_sts = 1;
        @sysvar::Sensors::Engine_sts   = 1;
        @sysvar::Sensors::Batt_Percent = 0;
        @sysvar::Sensors::Batt_Chg_Sts = 0;
        @sysvar::Sensors::Batt_Voltage = battFaultVoltage_arr[count%4];

        while(1)
        {
          @sysvar::UDS::Send_msg = 1;
          if(TestWaitForMessage(Fault_sts_Rsp, 20) == 1)
          {
            TestGetWaitEventMsgData(faultRsp_msg);

            if(faultRsp_msg.BATT_Vol_Err_sts == 2)
            {

                preCondOk = 1;
                break;
            }
          }
        }
        


        /* 2) recovery 조건으로 변경 */
        @sysvar::Sensors::Ignition_sts = i;
        @sysvar::Sensors::Engine_sts   = j;
        @sysvar::Sensors::Batt_Percent = 0;
        @sysvar::Sensors::Batt_Chg_Sts = 0;
        @sysvar::Sensors::Batt_Voltage = RecoverybattVoltage;
        
        waitBattVoltageReference(20,RecoverybattVoltage);
        startIvsRecoveryTimer();
        /* IGN=1, ENG=1, Batt_Percent>=80 일 때만 recovery 기대 */
        expectRecovery = (i == 1 && j == 1 && RecoverybattVoltage <= 15000);
  
        while(time_cnt_ms <= 120)
        {
          @sysvar::UDS::Send_msg = 1;

          if(TestWaitForMessage(Fault_sts_Rsp, 20) == 1)
          {
            TestGetWaitEventMsgData(faultRsp_msg);

            if(faultRsp_msg.BATT_Vol_Err_sts == 1)
            {
              if(expectRecovery)
              {
                if(time_cnt_ms >= 90 && time_cnt_ms <= 110)
                {
                  recoveryDetectedInWindow = 1;
                  break;
                }
                else
                {
                  timingError = 1;
                  TestStepFail("2.4",
                               "Recovery timing error when IGN=%d, ENG=%d, battVoltage=%d, time=%dms",
                               i, j, RecoverybattVoltage, time_cnt_ms);
                  break;
                }
              }
              else
              {
                unexpectedRecoveryDetected = 1;
                TestStepFail("2.2",
                             "Unexpected recovery detected when IGN=%d, ENG=%d, battVoltage=%d, time=%dms",
                             i, j, RecoverybattVoltage, time_cnt_ms);
                break;
              }
            }
          }
        }

        /* 3) 기대값 판정 */
        if(expectRecovery)
        {
          if(recoveryDetectedInWindow == 1)
          {
            TestStepPass("2.3",
                         "Recovery detected as expected when IGN=%d, ENG=%d, battVoltage=%d, time=%dms",
                         i, j, RecoverybattVoltage,time_cnt_ms);
          }
          else if(timingError == 0)
          {
            TestStepFail("2.5",
                         "Recovery failed when IGN=%d, ENG=%d, battVoltage=%d",
                         i, j, RecoverybattVoltage);
          }
        }
        else
        {
          if(unexpectedRecoveryDetected == 0)
          {
            TestStepPass("2.6",
                         "No recovery as expected when IGN=%d, ENG=%d, battVoltage=%d",
                         i, j, RecoverybattVoltage);
          }
        }
      }
    }
  }
}



testcase tc_Recovery_From_NonFaultLevel2()
{

  int preCondOk;
  int unexpectedRecovery;
  int timingError;
  
  int battVoltage_arr[6] = {0,1,7500,14999,15000,15001};
  int RecoverybattVoltage;
  int idx;



  for (idx=0; idx<elCount(battVoltage_arr); idx++)  {
    RecoverybattVoltage  = battVoltage_arr[idx];
    for(i = 0; i <= 1; i++)
    {
      for(j = 0; j <= 1; j++)
      {
        initializeSysVar();
        clearAllFaults();
        cancelTimer(t_1ms);

        preCondOk = 0;
        unexpectedRecovery = 0;
        timingError = 0;

        /* 1) 시작 상태가 Fault level 2가 아님을 확인 */
        @sysvar::Sensors::Ignition_sts = 1;
        @sysvar::Sensors::Engine_sts   = 1;
        @sysvar::Sensors::Batt_Percent = 0;
        @sysvar::Sensors::Batt_Chg_Sts = 0;
        @sysvar::Sensors::Batt_Voltage = 0;

        waitBattVoltageReference(20,0);
        startIvsRecoveryTimer();
        while(time_cnt_ms <= 200)
        {
          @sysvar::UDS::Send_msg = 1;
          if(TestWaitForMessage(Fault_sts_Rsp, 20) == 1)
          {
            TestGetWaitEventMsgData(faultRsp_msg);

            if(faultRsp_msg.BATT_Vol_Err_sts != 2)
            {
              preCondOk = 1;
              break;
            }
          }
        }

        if(preCondOk == 0)
        {
          TestStepFail("3.0",
                       "Precondition failed: Fault level is still 2 before test (IGN=%d, ENG=%d, battVoltage=%d)",
                       i, j, RecoverybattVoltage);
          continue;
        }

        /* 2) recovery 조건처럼 보이는 입력 적용 */
        cancelTimer(t_1ms);

        @sysvar::Sensors::Ignition_sts = i;
        @sysvar::Sensors::Engine_sts   = j;
        @sysvar::Sensors::Batt_Percent = 0;
        @sysvar::Sensors::Batt_Chg_Sts = 0;
        @sysvar::Sensors::Batt_Voltage = RecoverybattVoltage;

        waitBattVoltageReference(20,RecoverybattVoltage);
        startIvsRecoveryTimer();
        while(time_cnt_ms <= 110)
        {
          @sysvar::UDS::Send_msg = 1;
          if(TestWaitForMessage(Fault_sts_Rsp, 20) == 1)
          {
            TestGetWaitEventMsgData(faultRsp_msg);

            if(faultRsp_msg.BATT_Vol_Err_sts == 1)
            {
              if(time_cnt_ms >= 90 && time_cnt_ms <= 110)
              {
                unexpectedRecovery = 1;
                break;
              }
              else
              {
                timingError = 1;
                TestStepFail("3.4",
                             "Unexpected recovery timing when IGN=%d, ENG=%d, battVoltage=%d, time=%dms",
                             i, j, RecoverybattVoltage, time_cnt_ms);
                break;
              }
            }
          }
        }

        /* 3) 기대값 판정: non-level-2에서는 모두 recovery되면 안 됨 */
        if(unexpectedRecovery == 0 && timingError == 0)
        {
          TestStepPass("3.1",
                       "No recovery as expected from non-level-2 state when IGN=%d, ENG=%d, battVoltage=%d",
                       i, j, RecoverybattVoltage);
        }
        else if(unexpectedRecovery == 1)
        {
          TestStepFail("3.2",
                       "Unexpected recovery detected from non-level-2 state when IGN=%d, ENG=%d, battVoltage=%d",
                       i, j, RecoverybattVoltage);
        }
      }
    }
  }
}



testcase tc_Clear_From_Level1()
{
  int preFaultOk;
  int preRecoveryOk;
  int clearAtExpectedCycle;
  int clearAtUnexpectedCycle;
  int battVoltage;


  
  for(battVoltage =0; battVoltage <15; battVoltage++){
      
      initializeSysVar();
      clearAllFaults();
      
    
      preFaultOk = 0;
      preRecoveryOk = 0;
      clearAtExpectedCycle = 0;
      clearAtUnexpectedCycle = 0;
    
      /* 1) 먼저 Fault level 2 만들기 */
      @sysvar::Sensors::Ignition_sts = 1;
      @sysvar::Sensors::Engine_sts   = 1;
      @sysvar::Sensors::Batt_Percent = 0;
      @sysvar::Sensors::Batt_Chg_Sts = 0;
      @sysvar::Sensors::Batt_Voltage = 20001;
    
      waitBattVoltageReference(20, 20001);
    
      while(1)
      {
          @sysvar::UDS::Send_msg = 1;
          if(TestWaitForMessage(Fault_sts_Rsp, 20) == 1)
          {
            TestGetWaitEventMsgData(faultRsp_msg);
      
            if(faultRsp_msg.BATT_Vol_Err_sts == 2)
            {
                preFaultOk = 1;
                break;
            } 
          }
      }
    
      if(preFaultOk == 0)
      {
        TestStepFail("4.0", "Precondition fail: level 2 not reached");
        return;
      }
    
      /* 2) Recovery시켜서 Fault level 1 만들기 */
      @sysvar::Sensors::Batt_Percent = 0;
      @sysvar::Sensors::Batt_Chg_Sts = 0;
      @sysvar::Sensors::Batt_Voltage = battVoltage;
      
      cancelTimer(t_1ms);
      time_cnt_ms = 0;
      flag = 0;
    
      waitBattVoltageReference(20,battVoltage);
      
      while(1)
      {
        @sysvar::UDS::Send_msg =1;
        if(TestWaitForMessage(Fault_sts_Rsp, 20) == 1)
        {
          TestGetWaitEventMsgData(faultRsp_msg);
    
          if(faultRsp_msg.BATT_Vol_Err_sts == 1)
            {
              preRecoveryOk = 1;
              break;
            }
          }
      }
      
      
      if(preRecoveryOk == 0)
      {
        TestStepFail("4.0", "Precondition fail: level 1 not reached");
        return;
      }
    
      /* 3) Clear 검사 시작 전에 cycle counter만 리셋 */
      Ign_switch_cnt = 0;
      flag = i;
      
      
      while(1)
      {
        if(Ign_switch_cnt > 100)
        {
          break;
        }
        
        if(@sysvar::Sensors::Ignition_sts == 0)
        {
          @sysvar::Sensors::Ignition_sts = 1;
          waitIGNReference(10, 1);
        }
        else
        {
          @sysvar::Sensors::Ignition_sts = 0;
          waitIGNReference(10, 0);
        }
        @sysvar::UDS::Send_msg =1;
        if(TestWaitForMessage(Fault_sts_Rsp, 20) == 1)
        {
          TestGetWaitEventMsgData(faultRsp_msg);
    
          if(faultRsp_msg.BATT_Vol_Err_sts == 0)
          {
            if(Ign_switch_cnt == 50 && i == 1)
            {
              clearAtExpectedCycle = 1;
              break;
            }
            else
            {
              clearAtUnexpectedCycle = 1;
              break;
            }
            
          }
        }
      }
    
      if(clearAtExpectedCycle == 1)
      {
        TestStepPass("4.1",
                     "Clear Pass: level 1 became 0 at expected cycle count, Cycle_cnt=%d, battVoltage=%d",
                     Ign_switch_cnt,battVoltage);
      }
      else if(clearAtUnexpectedCycle == 1)
      {
        TestStepFail("4.2",
                     "Unexpected clear: level 1 became 0 at wrong cycle count, Cycle_cnt=%d, battVoltage=%d",
                     Ign_switch_cnt,battVoltage);
      }
      else
      {
        TestStepFail("4.3",
                     "Clear Fail: level 1 did not become 0 until max cycle count, Cycle_cnt=%d, battVoltage=%d",
                     Ign_switch_cnt,battVoltage);
      }    
    }
}

testcase tc_Clear_From_Level1_engine_off()
{
  int preFaultOk;
  int preRecoveryOk;
  int clearAtExpectedCycle;
  int clearAtUnexpectedCycle;
  int battVoltage;


  
  for(battVoltage =0; battVoltage <15; battVoltage++){
      
      initializeSysVar();
      clearAllFaults();
      
    
      preFaultOk = 0;
      preRecoveryOk = 0;
      clearAtExpectedCycle = 0;
      clearAtUnexpectedCycle = 0;
    
      /* 1) 먼저 Fault level 2 만들기 */
      @sysvar::Sensors::Ignition_sts = 1;
      @sysvar::Sensors::Engine_sts   = 1;
      @sysvar::Sensors::Batt_Percent = 0;
      @sysvar::Sensors::Batt_Chg_Sts = 0;
      @sysvar::Sensors::Batt_Voltage = 20001;
    
      waitBattVoltageReference(20, 20001);
    
      while(1)
      {
          @sysvar::UDS::Send_msg = 1;
          if(TestWaitForMessage(Fault_sts_Rsp, 20) == 1)
          {
            TestGetWaitEventMsgData(faultRsp_msg);
      
            if(faultRsp_msg.BATT_Vol_Err_sts == 2)
            {
                preFaultOk = 1;
                break;
            } 
          }
      }
    
      if(preFaultOk == 0)
      {
        TestStepFail("4.0", "Precondition fail: level 2 not reached");
        return;
      }
    
      /* 2) Recovery시켜서 Fault level 1 만들기 */
      @sysvar::Sensors::Batt_Percent = 0;
      @sysvar::Sensors::Batt_Chg_Sts = 0;
      @sysvar::Sensors::Batt_Voltage = battVoltage;
      
      cancelTimer(t_1ms);
      time_cnt_ms = 0;
      flag = 0;
    
      waitBattVoltageReference(20,battVoltage);
      
      while(1)
      {
        @sysvar::UDS::Send_msg =1;
        if(TestWaitForMessage(Fault_sts_Rsp, 20) == 1)
        {
          TestGetWaitEventMsgData(faultRsp_msg);
    
          if(faultRsp_msg.BATT_Vol_Err_sts == 1)
            {
              preRecoveryOk = 1;
              break;
            }
          }
      }
      
      
      if(preRecoveryOk == 0)
      {
        TestStepFail("4.0", "Precondition fail: level 1 not reached");
        return;
      }
    
      /* 3) Clear 검사 시작 전에 cycle counter만 리셋 */
      @sysvar::Sensors::Engine_sts = 0;
      waitEngineReference(20,0);
      Ign_switch_cnt = 0;
      flag = i;
      
      
      
      
      while(1)
      {
        if(Ign_switch_cnt > 100)
        {
          break;
        }
        
        if(@sysvar::Sensors::Ignition_sts == 0)
        {
          @sysvar::Sensors::Ignition_sts = 1;
          waitIGNReference(10, 1);
        }
        else
        {
          @sysvar::Sensors::Ignition_sts = 0;
          waitIGNReference(10, 0);
        }
        @sysvar::UDS::Send_msg =1;
        if(TestWaitForMessage(Fault_sts_Rsp, 20) == 1)
        {
          TestGetWaitEventMsgData(faultRsp_msg);
    
          if(faultRsp_msg.BATT_Vol_Err_sts == 0)
          {
            if(Ign_switch_cnt == 50 && i == 1)
            {
              clearAtExpectedCycle = 1;
              break;
            }
            else
            {
              clearAtUnexpectedCycle = 1;
              break;
            }
            
          }
        }
      }
    
      if(clearAtExpectedCycle == 1)
      {
        TestStepFail("4.1",
                     "Clear with Engine 0: level 1 became 0 at expected cycle count, Cycle_cnt=%d, battVoltage=%d",
                     Ign_switch_cnt,battVoltage);
      }
      else if(clearAtUnexpectedCycle == 1)
      {
        TestStepFail("4.2",
                     "Unexpected clear: level 1 became 0 at wrong cycle count, Cycle_cnt=%d, battVoltage=%d, Engine=%d",
                     Ign_switch_cnt,battVoltage,0);
      }
      else
      {
        TestStepFail("4.3",
                     "Clear Fail: level 1 did not become 0 until max cycle count, Cycle_cnt=%d, battVoltage=%d",
                     Ign_switch_cnt,battVoltage);
      }    
    }
}


testcase tc_Clear_From_Level2()
{
  int preFaultOk;
  int preRecoveryOk;
  int clearAtExpectedCycle;
  int clearAtUnexpectedCycle;
  int battVoltage;


  
  for(battVoltage =15; battVoltage <32767; battVoltage+=100){
      
      initializeSysVar();
      clearAllFaults();
      
    
      preFaultOk = 0;
      preRecoveryOk = 0;
      clearAtExpectedCycle = 0;
      clearAtUnexpectedCycle = 0;
    
      /* 1) 먼저 Fault level 2 만들기 */
      @sysvar::Sensors::Ignition_sts = 1;
      @sysvar::Sensors::Engine_sts   = 1;
      @sysvar::Sensors::Batt_Percent = 0;
      @sysvar::Sensors::Batt_Chg_Sts = 0;
      @sysvar::Sensors::Batt_Voltage = 20001;
    
      waitBattVoltageReference(20, 20001);
    
      while(1)
      {
          @sysvar::UDS::Send_msg = 1;
          if(TestWaitForMessage(Fault_sts_Rsp, 20) == 1)
          {
            TestGetWaitEventMsgData(faultRsp_msg);
      
            if(faultRsp_msg.BATT_Vol_Err_sts == 2)
            {
                preFaultOk = 1;
                break;
            } 
          }
      }
    
      if(preFaultOk == 0)
      {
        TestStepFail("4.0", "Precondition fail: level 2 not reached");
        return;
      }
      
      @sysvar::Sensors::Batt_Percent = 0;
      @sysvar::Sensors::Batt_Chg_Sts = 0;
      @sysvar::Sensors::Batt_Voltage = battVoltage;
      
      waitBattVoltageReference(20, battVoltage);
    
      /* 3) Clear 검사 시작 전에 cycle counter만 리셋 */
      Ign_switch_cnt = 0;
      flag = i;
      
      
      while(1)
      {
        if(Ign_switch_cnt > 100)
        {
          break;
        }
        
        if(@sysvar::Sensors::Ignition_sts == 0)
        {
          @sysvar::Sensors::Ignition_sts = 1;
          waitIGNReference(10, 1);
        }
        else
        {
          @sysvar::Sensors::Ignition_sts = 0;
          waitIGNReference(10, 0);
        }
        @sysvar::UDS::Send_msg =1;
        if(TestWaitForMessage(Fault_sts_Rsp, 20) == 1)
        {
          TestGetWaitEventMsgData(faultRsp_msg);
    
          if(faultRsp_msg.BATT_Vol_Err_sts == 0)
          {
            if(Ign_switch_cnt == 50 && i == 1)
            {
              clearAtExpectedCycle = 1;
              break;
            }
            else
            {
              clearAtUnexpectedCycle = 1;
              break;
            }
            
          }
        }
      }
    
      if(clearAtExpectedCycle == 1)
      {
        testStepFail("4.1",
                     "Clear level 2 became 0 at expected cycle count, Cycle_cnt=%d, battVoltage=%d",
                     Ign_switch_cnt,battVoltage);
      }
      else if(clearAtUnexpectedCycle == 1)
      {
        TestStepFail("4.2",
                     "Unexpected clear: level 2 became 0 at wrong cycle count, Cycle_cnt=%d, battVoltage=%d",
                     Ign_switch_cnt,battVoltage);
      }
      else
      {
        testStepPass("4.3",
                     "Clear Pass: level 2 did not become 0 until max cycle count, Cycle_cnt=%d, battVoltage=%d",
                     Ign_switch_cnt,battVoltage);
      }    
    }
}



